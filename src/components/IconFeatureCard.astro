---
import type { LocalizedText } from "../lib/i18n";
import Icon from "./Icon.astro";
import T from "./T.astro";

interface Props {
  icon?: string;
  no?: string;
  title: LocalizedText;
  desc?: LocalizedText;
  variant?: "panel" | "row";
}

const { icon, no, title, desc, variant = "panel" } = Astro.props;
const isRow = variant === "row";
---

<div
  data-reveal={isRow ? "left" : "up"}
  class:list={[
    "group border-line relative h-full",
    isRow
      ? "border-t py-6"
      : "card-interactive bg-surface overflow-hidden rounded-[var(--radius-card)] border p-6",
  ]}
>
  {
    !isRow && (
      <span
        class="bg-ember-500 absolute inset-x-0 top-0 h-1 origin-left scale-x-0 transition-transform duration-300 group-hover:scale-x-100"
        aria-hidden="true"
      />
    )
  }
  <div class="flex items-start gap-4">
    {
      icon && (
        <div class="bg-brand-500 ring-brand-100 group-hover:bg-ember-500 group-hover:ring-ember-100 inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-white ring-4 transition-all duration-200 group-hover:scale-105">
          <Icon name={icon} class="h-6 w-6" />
        </div>
      )
    }
    <div class="min-w-0">
      <h3 class="font-display text-brand-700 text-xl font-semibold">
        {no && <span class="text-ember-600">{no}) </span>}
        <T text={title} />
      </h3>
    </div>
  </div>
  {
    desc && (
      <p
        class:list={[
          "text-muted mt-4 text-[15px] leading-relaxed",
          !isRow && "border-line border-t pt-4",
        ]}
      >
        <T text={desc} />
      </p>
    )
  }
</div>
