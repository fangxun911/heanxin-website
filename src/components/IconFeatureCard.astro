---
import type { LocalizedText } from "../lib/i18n";
import Icon from "./Icon.astro";

interface Props {
  icon?: string;
  title: LocalizedText;
  desc?: LocalizedText;
}

const { icon, title, desc } = Astro.props;
---

<div class="card-base group h-full p-6 transition-transform duration-200 hover:-translate-y-1">
  {
    icon && (
      <div class="bg-brand-50 text-brand-500 group-hover:bg-brand-500 mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl transition-colors group-hover:text-white">
        <Icon name={icon} class="h-6 w-6" />
      </div>
    )
  }
  <h3 class="font-display text-brand-700 text-lg font-semibold">{title.en}</h3>
  <p class="text-muted mt-0.5 text-sm font-medium">{title.zh}</p>
  {
    desc && (
      <p class="text-muted mt-3 text-sm leading-relaxed">
        {desc.en}
        <span class="mt-1 block text-xs opacity-80">{desc.zh}</span>
      </p>
    )
  }
</div>
