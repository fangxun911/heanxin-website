---
import type { LocalizedText } from "../lib/i18n";
import { url } from "../lib/i18n";
import { Picture } from "astro:assets";
import { resolveImage, responsiveWidths } from "../lib/images";
import Icon from "./Icon.astro";
import T from "./T.astro";

interface ImageAsset {
  src: string;
  width: number;
  height: number;
  alt: LocalizedText;
}

interface Cta {
  label: LocalizedText;
  href: string;
  icon?: string;
}

interface Props {
  title: LocalizedText;
  subtitle: LocalizedText;
  image: ImageAsset;
  primaryCta: Cta;
  secondaryCta?: Cta;
}

const { title, subtitle, image, primaryCta, secondaryCta } = Astro.props;
const source = resolveImage(image.src);
const widths = responsiveWidths(source, [480, 768, 1024, 1280, 1672]);
---

<section class="home-hero relative overflow-hidden">
  <div class="home-hero__layout container-wide relative z-10">
    <div data-reveal="left" class="home-hero__copy relative">
      <h1
        class="home-hero__title font-display text-brand-800 heading-measure text-4xl leading-[1.05] font-bold sm:text-5xl xl:text-6xl"
      >
        <T text={title} />
      </h1>
      <p class="text-brand-500 mt-4 max-w-xl text-xl leading-snug font-semibold">
        <span lang="en">Factory-Direct. Mold Development. OEM & ODM.</span>
        <span lang="zh">工厂直供 · 模具开发 · OEM / ODM 定制</span>
      </p>
      <p class="text-muted mt-4 max-w-xl leading-relaxed">
        <T text={subtitle} />
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href={url(primaryCta.href)}
          class="bg-brand-500 hover:bg-brand-600 inline-flex items-center justify-center gap-2 rounded-lg px-7 py-3.5 text-sm font-semibold text-white shadow-[var(--shadow-ember)] transition hover:-translate-y-0.5"
        >
          <Icon name={primaryCta.icon ?? "document"} class="h-5 w-5" />
          <T text={primaryCta.label} />
        </a>
        {
          secondaryCta && (
            <a
              href={url(secondaryCta.href)}
              class="border-brand-300 text-brand-600 hover:bg-brand-50 inline-flex items-center justify-center gap-2 rounded-lg border bg-white/70 px-7 py-3.5 text-sm font-semibold transition hover:-translate-y-0.5"
            >
              <Icon name={secondaryCta.icon ?? "mail"} class="h-5 w-5" />
              <T text={secondaryCta.label} />
            </a>
          )
        }
      </div>
    </div>
  </div>

  <Picture
    src={source}
    formats={["avif"]}
    fallbackFormat="webp"
    widths={widths}
    width={source.width}
    height={source.height}
    alt=""
    loading="eager"
    decoding="async"
    fetchpriority="high"
    sizes="100vw"
    pictureAttributes={{ class: "contents" }}
    class="home-hero__background pointer-events-none"
    aria-hidden="true"
  />
</section>

<style>
  .home-hero {
    background: var(--color-canvas);
    isolation: isolate;
  }

  .home-hero__background {
    position: absolute;
    inset: 0 0 0 auto;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: right center;
    animation: hero-media-in 1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .home-hero__layout {
    display: grid;
    min-height: clamp(40rem, calc(100svh - 4rem), 54rem);
    grid-template-columns: minmax(0, 42rem) minmax(0, 1fr);
    align-items: center;
    padding-block: 4rem;
  }

  .home-hero__copy {
    width: min(40vw, 42rem);
  }

  @keyframes hero-media-in {
    from {
      opacity: 0;
      transform: scale(1.025);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (min-width: 1536px) {
    .home-hero__title {
      font-size: 4.5rem;
    }

    :global(html[data-lang="en"]) .home-hero__title {
      max-width: 42rem;
      font-size: 3.5rem;
    }
  }

  @media (max-width: 1023px) {
    .home-hero__layout {
      display: block;
      min-height: 0;
      padding-block: 3rem 1.5rem;
    }

    .home-hero__copy {
      width: 100%;
      max-width: 42rem;
    }

    .home-hero__background {
      position: relative;
      display: block;
      width: 100%;
      height: auto;
      aspect-ratio: 1672 / 941;
      object-position: right bottom;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-hero__background {
      animation: none;
    }
  }
</style>
