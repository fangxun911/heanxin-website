---
import type { LocalizedText } from "../lib/i18n";
import PhotoPlaceholder from "./PhotoPlaceholder.astro";
import T from "./T.astro";

interface Props {
  no: string;
  title: LocalizedText;
  desc?: LocalizedText;
  imageAlt?: LocalizedText;
  tags?: LocalizedText[];
  kind?: LocalizedText;
  tone?: "light" | "dark";
  featured?: boolean;
  class?: string;
}

const {
  no,
  title,
  desc,
  imageAlt,
  tags = [],
  kind,
  tone = "light",
  featured = false,
  class: className = "",
} = Astro.props;

const isDark = tone === "dark";
const cardTone = isDark
  ? "border-white/12 bg-white/[0.07] text-white hover:border-spark-400/55 hover:bg-white/[0.10]"
  : "border-line bg-white text-ink shadow-[var(--shadow-card)] hover:-translate-y-1.5 hover:border-spark-400/60";
const placeholderTone = isDark
  ? "border-0 bg-brand-900/45 transition-transform duration-700 ease-out group-hover:scale-[1.025]"
  : "border-0 bg-brand-50 transition-transform duration-700 ease-out group-hover:scale-[1.025]";
---

<article
  data-reveal
  class:list={[
    "group relative h-full overflow-hidden rounded-[var(--radius-card)] border transition duration-500",
    cardTone,
    featured && "sm:col-span-2",
    className,
  ]}
>
  <span
    class="bg-ember-500 absolute inset-x-0 top-0 z-20 h-1 origin-left scale-x-0 transition-transform duration-500 group-hover:scale-x-100"
    aria-hidden="true"></span>

  {
    imageAlt ? (
      <div class:list={[featured && "lg:grid lg:h-full lg:grid-cols-[1.08fr_0.92fr]"]}>
        <div class="relative overflow-hidden">
          <PhotoPlaceholder
            alt={imageAlt}
            ratio="video"
            labelStyle="none"
            class={`${placeholderTone} rounded-none ${
              featured ? "lg:aspect-auto lg:h-full lg:min-h-[18rem]" : ""
            }`}
          />
          <div
            class="from-brand-900/35 pointer-events-none absolute inset-0 bg-gradient-to-t via-transparent to-transparent"
            aria-hidden="true"
          />
          <div class="absolute inset-x-0 top-0 flex items-start justify-between gap-4 p-4">
            <span class="font-display bg-brand-900/70 rounded-full border border-white/20 px-3 py-1 text-xs font-bold tracking-[0.18em] text-white backdrop-blur-sm">
              {no}
            </span>
            {kind && (
              <span class="text-brand-700 rounded-full border border-white/20 bg-white/80 px-3 py-1 text-[11px] font-semibold tracking-wider uppercase backdrop-blur-sm">
                <T text={kind} />
              </span>
            )}
          </div>
          <div
            class="pointer-events-none absolute inset-y-0 -left-1/2 w-1/3 -skew-x-12 bg-gradient-to-r from-transparent via-white/25 to-transparent opacity-0 transition-all duration-700 group-hover:left-[120%] group-hover:opacity-100"
            aria-hidden="true"
          />
        </div>

        <div class:list={["relative flex flex-col p-5 sm:p-6", featured && "lg:justify-center"]}>
          <p
            class:list={[
              "font-display text-xs font-bold tracking-[0.18em] uppercase",
              isDark ? "text-ember-300" : "text-ember-700",
            ]}
          >
            <>
              <span lang="en">
                {no} / {title.en}
              </span>
              <span lang="zh">
                {no} / {title.zh}
              </span>
            </>
          </p>
          <h3
            class:list={[
              "font-display mt-3 text-2xl leading-tight font-semibold",
              isDark ? "text-white" : "text-brand-800",
              featured && "sm:text-3xl",
            ]}
          >
            <T text={title} />
          </h3>
          {desc && (
            <p
              class:list={[
                "mt-3 text-[15px] leading-relaxed",
                isDark ? "text-brand-100/80" : "text-muted",
              ]}
            >
              <T text={desc} />
            </p>
          )}
          {tags.length > 0 && (
            <ul class="mt-5 flex flex-wrap gap-2" aria-label="Key properties / 关键特性">
              {tags.map((tag) => (
                <li
                  class:list={[
                    "rounded-full border px-3 py-1 text-xs font-semibold",
                    isDark
                      ? "text-brand-100 border-white/12 bg-white/8"
                      : "border-brand-100 bg-brand-50 text-brand-600",
                  ]}
                >
                  <T text={tag} />
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    ) : (
      <div class="p-6">
        <span
          class="font-display text-ember-100 group-hover:text-ember-200 absolute top-3 right-4 text-6xl leading-none font-bold transition-colors"
          aria-hidden="true"
        >
          {no}
        </span>
        <p class="font-display text-ember-700 text-sm font-bold tracking-widest">{no}</p>
        <h3 class="font-display text-brand-700 mt-2 text-xl font-semibold">
          <T text={title} />
        </h3>
        {desc && (
          <p class="text-muted mt-3 text-[15px] leading-relaxed">
            <T text={desc} />
          </p>
        )}
      </div>
    )
  }
</article>
