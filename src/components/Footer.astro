---
import { site, url } from "../lib/i18n";
import WaveDivider from "./WaveDivider.astro";
import Icon from "./Icon.astro";

const { company, contact, footer, nav } = site;
const year = new Date().getFullYear();
---

<footer class="relative mt-24">
  <WaveDivider fill="#0d2b6b" />
  <div class="bg-brand-700 text-brand-100">
    <div class="container-page grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-2">
        <div class="flex items-center gap-2.5">
          <span
            class="font-display flex h-9 w-9 items-center justify-center rounded-lg bg-white/15 text-lg font-bold text-white"
            >禾</span
          >
          <span class="font-display text-base font-bold tracking-wide text-white uppercase"
            >{company.shortName.en}</span
          >
        </div>
        <p class="mt-1 text-sm font-medium text-white">{company.name.zh}</p>
        <p class="mt-4 max-w-md text-sm leading-relaxed text-brand-100/85">
          {footer.blurb.en}
          <span class="mt-1 block opacity-80">{footer.blurb.zh}</span>
        </p>
      </div>

      <div>
        <h2 class="font-display text-sm font-semibold tracking-wider text-white uppercase">
          Navigation · 导航
        </h2>
        <ul class="mt-4 space-y-2 text-sm">
          {
            nav.map((item) => (
              <li>
                <a href={url(item.href)} class="transition hover:text-white">
                  {item.label.zh} · {item.label.en}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2 class="font-display text-sm font-semibold tracking-wider text-white uppercase">
          Contact · 联系
        </h2>
        <ul class="mt-4 space-y-3 text-sm">
          <li class="flex gap-2">
            <Icon name="home" class="h-5 w-5 shrink-0 opacity-70" />
            <span>{contact.address.zh}</span>
          </li>
          <li>
            <a
              href={`https://wa.me/${contact.phoneRaw}`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 transition hover:text-white"
            >
              <Icon name="handshake" class="h-5 w-5 shrink-0 opacity-70" />
              WhatsApp: {contact.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${contact.email}`}
              class="inline-flex items-center gap-2 transition hover:text-white"
            >
              <Icon name="medical" class="h-5 w-5 shrink-0 opacity-70" />
              {contact.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10">
      <div
        class="container-page flex flex-col gap-2 py-5 text-xs text-brand-100/70 sm:flex-row sm:items-center sm:justify-between"
      >
        <p>© {year} {company.name.en}. All rights reserved.</p>
        <p>{company.name.zh} · 版权所有</p>
      </div>
    </div>
  </div>
</footer>
