---
import type { LocalizedText } from "../lib/i18n";
import Icon from "./Icon.astro";
import T from "./T.astro";

interface CapabilityItem {
  icon: string;
  title: LocalizedText;
  desc: LocalizedText;
}

interface Props {
  items: CapabilityItem[];
}

const { items } = Astro.props;
---

<div data-reveal="scale" class="border-line border-y py-2">
  <div class="grid sm:grid-cols-2 lg:grid-cols-4">
    {
      items.map((item, index) => (
        <div
          class:list={[
            "flex items-center gap-4 px-4 py-5 lg:px-6",
            index > 0 && "border-line max-sm:border-t sm:odd:border-l lg:border-l",
            index === 2 && "border-line sm:border-t lg:border-t-0",
          ]}
        >
          <div class="text-brand-500 bg-canvas inline-flex h-14 w-14 shrink-0 items-center justify-center rounded-full shadow-sm">
            <Icon name={item.icon} class="h-7 w-7" />
          </div>
          <div class="min-w-0">
            <p class="font-display text-brand-600 text-xl leading-tight font-bold">
              <T text={item.title} />
            </p>
            <p class="text-brand-800/80 mt-1 text-sm leading-snug">
              <T text={item.desc} />
            </p>
          </div>
        </div>
      ))
    }
  </div>
</div>
