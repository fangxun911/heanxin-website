---
import type { LocalizedText } from "../lib/i18n";
import { url } from "../lib/i18n";
import Icon from "./Icon.astro";
import ResponsiveImage from "./ResponsiveImage.astro";
import T from "./T.astro";

interface ImageAsset {
  src: string;
  width: number;
  height: number;
  alt: LocalizedText;
}

interface Props {
  icon: string;
  title: LocalizedText;
  desc: LocalizedText;
  image: ImageAsset;
  href: string;
}

const { icon, title, desc, image, href } = Astro.props;
---

<a
  data-reveal="up"
  href={url(href)}
  class="group border-line hover:border-brand-200 relative grid h-full grid-rows-[auto_1fr] overflow-hidden rounded-[var(--radius-card)] border bg-white transition duration-300 hover:-translate-y-1 hover:shadow-[var(--shadow-card)]"
>
  <div class="bg-surface relative aspect-[4/3] overflow-hidden">
    <ResponsiveImage
      image={image}
      fit="contain"
      sizes="(min-width: 1536px) 22vw, (min-width: 1024px) 44vw, 100vw"
      class="h-full w-full bg-transparent p-5"
      imgClass="mix-blend-multiply drop-shadow-md transition duration-500 group-hover:scale-105"
    />
    <div
      class="bg-brand-800 absolute top-4 left-4 inline-flex h-10 w-10 items-center justify-center rounded-full text-white shadow-sm"
    >
      <Icon name={icon} class="h-5 w-5" />
    </div>
  </div>
  <div class="min-w-0 p-5">
    <h3 class="font-display text-brand-700 text-base leading-snug font-semibold sm:text-lg">
      <T text={title} />
    </h3>
    <p class="text-muted mt-2 text-sm leading-relaxed">
      <T text={desc} />
    </p>
  </div>
  <span
    class="border-brand-200 text-brand-500 group-hover:bg-brand-500 absolute right-4 bottom-4 inline-flex h-8 w-8 items-center justify-center rounded-full border transition group-hover:text-white"
    aria-hidden="true"
  >
    <Icon name="chevronRight" class="h-4 w-4" />
  </span>
</a>
