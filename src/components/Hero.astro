---
import type { LocalizedText } from "../lib/i18n";
import { url } from "../lib/i18n";

interface Cta {
  label: LocalizedText;
  href: string;
}

interface Props {
  eyebrow?: LocalizedText;
  title: LocalizedText;
  subtitle?: LocalizedText;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  compact?: boolean;
}

const { eyebrow, title, subtitle, primaryCta, secondaryCta, compact = false } = Astro.props;
---

<section
  class={`from-brand-700 via-brand-600 to-brand-800 relative overflow-hidden bg-gradient-to-br ${compact ? "py-20" : "py-28 sm:py-32"}`}
>
  <!-- Decorative circuit grid -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.12]"
    style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 48px 48px;"
    aria-hidden="true"
  >
  </div>
  <div class="bg-accent/30 pointer-events-none absolute -top-24 -right-24 h-96 w-96 rounded-full blur-3xl"></div>

  <div class="container-page relative">
    <div class="max-w-3xl">
      {eyebrow && <p class="text-accent-soft eyebrow">{eyebrow.en} · {eyebrow.zh}</p>}
      <h1
        class="font-display mt-4 text-4xl leading-[1.05] font-bold tracking-tight text-white uppercase sm:text-5xl lg:text-6xl"
      >
        {title.en}
      </h1>
      <p class="text-brand-100 mt-3 text-xl font-medium sm:text-2xl">{title.zh}</p>
      {
        subtitle && (
          <p class="text-brand-100/90 mt-6 max-w-2xl text-base leading-relaxed sm:text-lg">
            {subtitle.en}
            <span class="mt-1 block text-sm opacity-80">{subtitle.zh}</span>
          </p>
        )
      }
      {
        (primaryCta || secondaryCta) && (
          <div class="mt-9 flex flex-wrap gap-4">
            {primaryCta && (
              <a
                href={url(primaryCta.href)}
                class="text-brand-700 inline-flex items-center rounded-full bg-white px-6 py-3 text-sm font-semibold shadow-lg transition hover:bg-brand-50"
              >
                {primaryCta.label.en} · {primaryCta.label.zh}
              </a>
            )}
            {secondaryCta && (
              <a
                href={url(secondaryCta.href)}
                class="inline-flex items-center rounded-full border border-white/40 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
              >
                {secondaryCta.label.en} · {secondaryCta.label.zh}
              </a>
            )}
          </div>
        )
      }
    </div>
  </div>
</section>
