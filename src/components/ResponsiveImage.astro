---
import type { LocalizedText } from "../lib/i18n";
import { Picture } from "astro:assets";
import { resolveImage, responsiveWidths } from "../lib/images";

interface ImageAsset {
  src: string;
  width: number;
  height: number;
  alt: LocalizedText;
}

interface Props {
  image: ImageAsset;
  aspect?: "auto" | "square" | "video" | "wide" | "banner" | "portrait";
  class?: string;
  imgClass?: string;
  loading?: "lazy" | "eager";
  priority?: boolean;
  fit?: "cover" | "contain";
  sizes?: string;
  widths?: number[];
}

const {
  image,
  aspect = "auto",
  class: className = "",
  imgClass = "",
  loading = "lazy",
  priority = false,
  fit = "cover",
  sizes = "100vw",
  widths = [320, 480, 640, 960],
} = Astro.props;

const aspectClass = {
  auto: "",
  square: "aspect-square",
  video: "aspect-video",
  wide: "aspect-[16/7]",
  banner: "aspect-[16/9]",
  portrait: "aspect-[4/5]",
}[aspect];

const fitClass = fit === "contain" ? "object-contain" : "object-cover";
const loadingValue = priority ? "eager" : loading;
const fetchPriority = priority ? "high" : undefined;
const alt = `${image.alt.en} / ${image.alt.zh}`;
const source = resolveImage(image.src);
const outputWidths = responsiveWidths(source, widths);
const outputWidth = outputWidths.at(-1) ?? source.width;
const outputHeight = Math.round((outputWidth / source.width) * source.height);
---

<div class:list={["bg-surface relative overflow-hidden", aspectClass, className]}>
  <Picture
    src={source}
    formats={["avif"]}
    fallbackFormat="webp"
    widths={outputWidths}
    width={outputWidth}
    height={outputHeight}
    alt={alt}
    loading={loadingValue}
    decoding="async"
    fetchpriority={fetchPriority}
    sizes={sizes}
    pictureAttributes={{ class: "contents" }}
    class:list={["h-full w-full", fitClass, imgClass]}
  />
</div>
