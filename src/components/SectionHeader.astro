---
import type { LocalizedText } from "../lib/i18n";

interface Props {
  eyebrow?: LocalizedText;
  title: LocalizedText;
  subtitle?: LocalizedText;
  align?: "left" | "center";
  tone?: "light" | "dark";
}

const { eyebrow, title, subtitle, align = "center", tone = "light" } = Astro.props;

const alignCls = align === "center" ? "mx-auto text-center" : "text-left";
const titleColor = tone === "dark" ? "text-white" : "text-brand-700";
const subColor = tone === "dark" ? "text-brand-100" : "text-muted";
---

<div class={`max-w-2xl ${alignCls}`}>
  {eyebrow && <p class="eyebrow">{eyebrow.en} · {eyebrow.zh}</p>}
  <h2
    class={`font-display mt-3 text-3xl font-semibold tracking-tight uppercase sm:text-4xl ${titleColor}`}
  >
    {title.en}
  </h2>
  <p class={`mt-1 text-lg font-medium ${subColor}`}>{title.zh}</p>
  {
    subtitle && (
      <p class={`mt-4 text-base leading-relaxed ${subColor}`}>
        {subtitle.en}
        <br />
        <span class="text-sm opacity-80">{subtitle.zh}</span>
      </p>
    )
  }
</div>
