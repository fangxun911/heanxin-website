---
import type { LocalizedText } from "../lib/i18n";
import T from "./T.astro";

interface Props {
  eyebrow?: LocalizedText;
  title: LocalizedText;
  subtitle?: LocalizedText;
  align?: "left" | "center";
  tone?: "light" | "dark";
  as?: "h1" | "h2";
  size?: "page" | "section" | "compact";
}

const {
  eyebrow,
  title,
  subtitle,
  align = "center",
  tone = "light",
  as: HeadingTag = "h2",
  size = "section",
} = Astro.props;

const alignCls = align === "center" ? "mx-auto text-center" : "text-left";
const titleColor = tone === "dark" ? "text-white" : "text-brand-700";
const subColor = tone === "dark" ? "text-brand-100" : "text-muted";
const eyebrowColor = tone === "dark" ? "text-ember-400" : "text-ember-700";
const barCenter = align === "center" ? "justify-center" : "";
const titleSize = {
  page: "text-4xl sm:text-5xl 2xl:text-6xl",
  section: "text-3xl sm:text-4xl 2xl:text-5xl",
  compact: "text-2xl sm:text-3xl",
}[size];
---

<div class={`max-w-3xl ${alignCls}`}>
  {
    eyebrow && (
      <p class={`eyebrow ${eyebrowColor}`}>
        <T text={eyebrow} />
      </p>
    )
  }
  <HeadingTag class={`font-display mt-3 leading-tight font-bold ${titleSize} ${titleColor}`}>
    <span lang="en" class="uppercase">{title.en}</span><span lang="zh">{title.zh}</span>
  </HeadingTag>
  <div class={`accent-bar mt-4 ${barCenter}`} aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </div>
  {
    subtitle && (
      <p class={`mt-4 text-lg leading-relaxed ${subColor}`}>
        <T text={subtitle} />
      </p>
    )
  }
</div>
