---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import T from "../../components/T.astro";
import news from "../../content/news.json";
import { url } from "../../lib/i18n";

export function getStaticPaths() {
  return news.articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
---

<BaseLayout title={article.title.zh} description={article.summary.zh}>
  <article class="container-page pt-10 pb-16 sm:pt-12">
    <a
      href={url("/news")}
      class="border-line text-brand-700 hover:border-ember-500 hover:text-ember-700 focus:ring-ember-200 inline-flex items-center gap-2 rounded-full border bg-white px-4 py-2 text-sm font-semibold transition hover:-translate-y-0.5 focus:ring-4 focus:outline-none"
    >
      <Icon name="chevronLeft" class="h-4 w-4" />
      <span lang="en">Back</span><span lang="zh">返回</span>
    </a>

    <div class="mt-8 grid gap-10 lg:grid-cols-[16rem_minmax(0,48rem)] lg:justify-center 2xl:gap-16">
      <aside class="lg:sticky lg:top-28 lg:self-start">
        <details open class="border-line border-y py-4">
          <summary class="font-display text-brand-700 cursor-pointer font-semibold">
            <T text={news.articleNavTitle} />
          </summary>
          <ol class="mt-4 space-y-3">
            {
              article.sections.map((section, index) => (
                <li>
                  <a
                    href={url(`/news/${article.slug}#section-${index + 1}`)}
                    class="text-muted hover:text-ember-700 flex gap-3 text-sm leading-snug transition"
                  >
                    <span class="text-ember-600 font-semibold">
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    <T text={section.heading} />
                  </a>
                </li>
              ))
            }
          </ol>
        </details>
      </aside>

      <div>
        <SectionHeader
          eyebrow={{ en: article.date, zh: article.date }}
          title={article.title}
          subtitle={article.summary}
          as="h1"
          align="left"
          size="page"
        />

        <div class="content-measure mt-12 space-y-10">
          {
            article.sections.map((section, index) => (
              <section
                id={`section-${index + 1}`}
                class="border-line scroll-mt-28 border-b pb-10 last:border-b-0 last:pb-0"
              >
                <h2 class="font-display text-brand-700 text-2xl font-semibold sm:text-3xl">
                  <T text={section.heading} />
                </h2>
                <p class="text-muted mt-4 leading-relaxed">
                  <T text={section.body} />
                </p>
              </section>
            ))
          }
        </div>
      </div>
    </div>
  </article>

  <section class="section-tint border-line border-y py-14">
    <div class="container-page flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="eyebrow text-ember-700">
          <span lang="en">Project Support</span><span lang="zh">项目支持</span>
        </p>
        <h2 class="font-display text-brand-700 mt-2 text-3xl font-bold">
          <span lang="en">Need a custom plastic part quote?</span><span lang="zh"
            >需要定制塑胶件报价？</span
          >
        </h2>
      </div>
      <a
        href={url("/contact#quote")}
        class="bg-ember-500 hover:bg-ember-600 inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5"
      >
        <span lang="en">Get a Quote</span><span lang="zh">获取报价</span>
      </a>
    </div>
  </section>
</BaseLayout>
